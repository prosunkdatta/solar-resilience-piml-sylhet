# ============================================================
# QX-01 .gitignore
# ============================================================

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data — raw NASA POWER files (too large for GitHub)
data/raw/*.csv
data/raw/*.nc
data/external/

# Processed arrays (regenerated by pipeline)
data/processed/*.npy
data/processed/*.csv

# Trained model weights (too large — share via release)
models/*.pt
models/checkpoints/

# Results (regenerated)
results/**/*.csv

# Figures (regenerated)
figures/**/*.png
figures/**/*.pdf

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Environment
.env
*.env

# LaTeX auxiliary files
paper/*.aux
paper/*.log
paper/*.out
paper/*.toc
paper/*.bbl
paper/*.blg
paper/*.synctex.gz

# BUT keep these tracked:
!data/raw/.gitkeep
!data/processed/.gitkeep
!models/.gitkeep
!results/metrics/.gitkeep
!results/resilience/.gitkeep
!results/ablation/.gitkeep
!figures/forecasting/.gitkeep
!figures/resilience/.gitkeep
!figures/features/.gitkeep
